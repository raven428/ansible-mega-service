root = true

[*]
indent_size = 2
indent_style = space
end_of_line = lf
max_line_length = 90
insert_final_newline = true
trim_trailing_whitespace = true

[{*.md,molecule/default/files/**}]
max_line_length = unset

[molecule/default/files/**]
insert_final_newline = unset
max_line_length = unset
indent_style = unset
end_of_line = unset

[molecule/prepare.sh]
max_line_length = 222
